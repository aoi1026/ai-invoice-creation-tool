// AI Invoice Tool — data model
// Multi-tenant: one Company has many Users (employees) with roles.
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Company {
  id         String   @id @default(cuid())
  name       String
  email      String?
  phone      String?
  address    String?
  taxId      String?  // 登録番号 / Tax registration number
  logoUrl    String?
  // Invoice numbering
  invoicePrefix String @default("INV-")
  nextNumber    Int    @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users      User[]
  clients    Client[]
  invoices   Invoice[]
  templates  InvoiceTemplate[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MEMBER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  invoices       Invoice[]        @relation("InvoiceCreator")
  passwordResets PasswordReset[]

  @@index([companyId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([companyId])
}

model InvoiceTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  // Defaults stored as JSON string
  currency     String   @default("JPY")
  taxRate      Float    @default(10)
  notes        String?
  paymentTerms String?
  itemsJson    String   @default("[]") // default line items
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Invoice {
  id            String        @id @default(cuid())
  number        String
  status        InvoiceStatus @default(DRAFT)
  currency      String        @default("JPY")
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  taxRate       Float         @default(10)
  // computed + stored for fast listing
  subtotal      Float         @default(0)
  taxAmount     Float         @default(0)
  total         Float         @default(0)
  notes         String?
  paymentTerms  String?
  // snapshot of recipient (so historical invoices stay stable)
  clientName    String
  clientEmail   String?
  clientAddress String?
  clientTaxId   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?  @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)

  items InvoiceItem[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([status])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  amount      Float   @default(0)
  position    Int     @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}
