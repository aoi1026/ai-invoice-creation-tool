# Database (SQLite by default — no setup required)
DATABASE_URL="file:./dev.db"

# Session signing secret. MUST be a long random string in production.
# Generate one with:  openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Anthropic API key — enables AI invoice generation + OCR extraction.
# Get one at https://console.anthropic.com . Leave empty to disable AI features.
ANTHROPIC_API_KEY=""
